# ── Bark 推送配置 ──────────────────────────
# 必填：Bark App 上显示的 Key（安装 Bark 后打开 App 即可看到）
BARK_KEY=your_bark_key_here
# Bark 服务器地址（默认公共服务器，自建可改）
BARK_URL=https://api.day.app

# ── 分析配置 ───────────────────────────────
# 获取最近 N 天的新闻
NEWS_DAYS=3
# 报告展示 Top N 家公司
TOP_N=15
# 定时执行时间（仅 --schedule 模式生效）
SCHEDULE_TIME=15:30

# ── 海外新闻（暂未启用）───────────────────
ENABLE_FOREIGN_NEWS=false
